{
  "name": "carbon",
  "description": "24-hour weather graph watchface for Pebble smartwatches",
  "author": {
    "name": "Cory Hughart",
    "url": "https://coryhughart.com"
  },
  "version": "1.1.0",
  "keywords": [
    "pebble-app"
  ],
  "private": true,
  "pebble": {
    "displayName": "Carbon",
    "uuid": "4a34b9c0-93b3-43ff-b1ba-a19d00cbcc60",
    "sdkVersion": "3",
    "enableMultiJS": true,
    "targetPlatforms": [
      "aplite",
      "basalt",
      "diorite",
      "emery",
      "flint"
    ],
    "watchapp": {
      "watchface": true
    },
    "capabilities": [
      "location",
      "configurable"
    ],
    "messageKeys": [
      "WEATHER_REQUEST",
      "WEATHER_TEMP",
      "WEATHER_TEMP_HIGH",
      "WEATHER_TEMP_LOW",
      "WEATHER_CODE",
      "WEATHER_PRECIP_PROB",
      "WEATHER_TEMP_HOURLY",
      "WEATHER_APPARENT_TEMP_HOURLY",
      "WEATHER_CLOUD_COVER",
      "WEATHER_HOURLY_CODE",
      "WEATHER_SUNRISE_HOUR",
      "WEATHER_SUNSET_HOUR",
      "WEATHER_FETCH_TIME",
      "CITY_NAME",
      "SETTING_TEMP_UNIT",
      "SETTING_DATE_FORMAT",
      "SETTING_ACCENT_COLOR",
      "SETTING_BATTERY_DISPLAY"
    ],
    "resources": {
      "media": [
        {
          "type": "font",
          "name": "CARBON_ICONS_12",
          "file": "fonts/IcoMoon-Regular.ttf",
          "characterRegex": "[\\uE000-\\uF9FF]"
        },
        {
          "type": "font",
          "name": "CARBON_ICONS_14",
          "file": "fonts/IcoMoon-Regular.ttf",
          "characterRegex": "[\\uE000-\\uF9FF]"
        },
        {
          "type": "font",
          "name": "CARBON_ICONS_18",
          "file": "fonts/IcoMoon-Regular.ttf",
          "characterRegex": "[\\uE000-\\uF9FF]"
        },
        {
          "type": "font",
          "name": "CARBON_ICONS_22",
          "file": "fonts/IcoMoon-Regular.ttf",
          "characterRegex": "[\\uE000-\\uF9FF]"
        }
      ]
    }
  },
  "scripts": {
    "gen-icons": "node scripts/gen-icons.js"
  },
  "dependencies": {
    "@rebble/clay": "^1.0.10"
  }
}
